#!/usr/bin/env perl

use strict;
use warnings;

use App::Schema::Deploy;

our $VERSION = 0.06;

# Run.
exit App::Schema::Deploy->new->run;

# Print version.
sub VERSION_MESSAGE {
	print $VERSION."\n";
	exit 0;
}

__END__

=pod

=encoding utf8

=head1 NAME

schema-deploy - Tool to deploy Schema.

=head1 SYNOPSIS

 schema-deploy [-d] [-h] [-p password] [-q] [-u user] [--version] dsn schema_module[@schema_version]

=head1 DESCRIPTION

C<schema-deploy> deploys a L<DBIx::Class> schema to a database. It accepts an
optional inline schema version suffix in the form C<schema_module@schema_version>.

=head1 ARGUMENTS

=over 8

=item * C<-d>

Drop tables before deploy.

=item * C<-h>

Print help.

=item * C<-p password>

Database password.

=item * C<-q>

Quiet mode.

=item * C<-u user>

Database user.

=item * C<--version>

Print version of script.

=item * C<dsn>

Database DSN.
e.g. dbi:SQLite:dbname=ex1.db

=item * C<schema_module[@schema_version]>

Name of Schema module. Must be a 'DBIx::Class::Schema' instance.

=back

=head1 EXAMPLE

 schema-deploy dbi:SQLite:dbname=commons.vote.db Schema::Commons::Vote@0.1.0

=head1 SEE ALSO

=over

=item L<schema-data>

Script to manipulation with data for Schema.

=back

